// Conformance kernel (template — placeholders filled per curated config).
//
// Assign each input double to __FIXED_TYPE__: Vitis applies its ap_fixed
// quantization (Q) + overflow (O) here. Then emit the raw __W__-bit stored pattern
// via .range(). The Python fixputils model quantizes the same doubles and must
// produce the identical bits — that bit-for-bit equality is the conformance proof.
#include <ap_fixed.h>
#include <ap_int.h>
#include <fstream>
#include <iostream>

int main(int argc, char** argv) {
    const char* in_path = (argc > 1) ? argv[1] : "in_values.txt";
    const char* out_path = (argc > 2) ? argv[2] : "out_bits.txt";

    std::ifstream fin(in_path);
    if (!fin) {
        std::cerr << "Failed to open input file: " << in_path << std::endl;
        return 1;
    }
    std::ofstream fout(out_path);
    if (!fout) {
        std::cerr << "Failed to open output file: " << out_path << std::endl;
        return 1;
    }

    double d;
    while (fin >> d) {
        __FIXED_TYPE__ x = d;                       // <-- Vitis quantizes here
        ap_uint<__W__> bits = x.range(__W__ - 1, 0); // raw stored bits
        fout << static_cast<unsigned long long>(bits) << "\n";
    }
    return 0;
}
